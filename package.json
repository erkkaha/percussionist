{
  "name": "percussionist",
  "version": "0.1.0",
  "private": true,
  "description": "Kubernetes-native orchestration for OpenCode agents",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "beatctl": "pnpm --filter @percussionist/cli exec tsx src/index.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  },
  "engines": {
    "node": ">=20"
  }
}
