{
  "name": "@percussionist/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web dashboard for percussionist",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/server/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@kubernetes/client-node": "^1.4.0",
    "@percussionist/api": "workspace:*",
    "@percussionist/kube": "workspace:*",
    "@tanstack/react-query": "^5.62.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "drizzle-kit": "^0.30.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0"
  }
}
