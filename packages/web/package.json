{
  "name": "@percussionist/web",
  "version": "0.1.193",
  "private": true,
  "type": "module",
  "description": "Web dashboard for percussionist",
  "scripts": {
    "dev": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.server.json && tsc -p tsconfig.client.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/server/migrate.ts",
    "test": "bun test tests/"
  },
  "dependencies": {
    "@hono/node-server": "2.0.4",
    "@kubernetes/client-node": "1.4.0",
    "@percussionist/api": "workspace:*",
    "@percussionist/kube": "workspace:*",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tanstack/react-query": "5.101.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "diff": "9.0.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.25",
    "katex": "0.17.0",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-diff-view": "3.3.3",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-router-dom": "7.16.0",
    "recharts": "3.8.1",
    "rehype-katex": "7.0.1",
    "rehype-mermaid": "3.0.0",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "shiki": "4.2.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss-animate": "1.0.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.14",
    "bun-types": "1.3.14",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "tailwindcss": "4.3.0",
    "vite": "8.0.16"
  }
}
