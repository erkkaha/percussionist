{
  "name": "@percussionist/web",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Web dashboard for percussionist",
  "scripts": {
    "dev": "bun --watch src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "pnpm build:client && pnpm build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -b tsconfig.server.json && tsc -p tsconfig.client.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/server/migrate.ts",
    "test": "bun test tests/"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@kubernetes/client-node": "^1.4.0",
    "@percussionist/api": "workspace:*",
    "@percussionist/kube": "workspace:*",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.62.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^7.0.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.6.0",
    "katex": "^0.16.11",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-diff-view": "^3.3.3",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.0",
    "rehype-katex": "^7.0.0",
    "rehype-mermaid": "^3.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^1.29.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "drizzle-kit": "^0.30.0",
    "tailwindcss": "^4.1.0",
    "vite": "^6.0.0"
  }
}
